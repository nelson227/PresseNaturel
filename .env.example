# Configuration Variables d'environnement

# Supabase (optionnel pour les futures intégrations)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_key

# Email (pour confirmation des commandes)
NEXT_PUBLIC_CONTACT_EMAIL=contact@pressenaturel.ca

# WhatsApp & Réseaux
NEXT_PUBLIC_WHATSAPP_NUMBER=your_number
NEXT_PUBLIC_INSTAGRAM_USERNAME=pressenaturel

# Analytics (Google Analytics, etc.)
NEXT_PUBLIC_GA_ID=

# API externe (stripe, etc.)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
