# Configuration Backend Pressé Naturel
# Copier ce fichier en .env et remplir les valeurs

# Base de données PostgreSQL (Railway)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# JWT Secret (générer une clé sécurisée)
JWT_SECRET="votre-secret-jwt-super-securise-a-changer"

# Port du serveur
PORT=3001

# URL du frontend (pour CORS)
FRONTEND_URL="http://localhost:3000"

# Admin par défaut (créé au premier démarrage)
ADMIN_EMAIL="admin@pressenaturel.com"
ADMIN_PASSWORD="PresseAdmin2024!"
